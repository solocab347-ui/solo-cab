<?xml version="1.0" encoding="utf-8"?>
<!--
  SoloCab — Désactive backup auto (cloud) et transfert d'appareil pour éviter
  la fuite de tokens auth / données sensibles via sauvegarde Google.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
